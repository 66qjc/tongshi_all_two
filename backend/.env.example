# Backend runtime
# 示例值仅用于通过格式检查，生产必须替换为新的强随机字符串。
SECRET_KEY=0123456789abcdef0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALLOWED_ORIGINS=https://example.com

# MySQL
DATABASE_URL=mysql+pymysql://tongshi_user:请替换为强密码@127.0.0.1:3306/tongshi?charset=utf8mb4
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=tongshi_user
MYSQL_PASSWORD=请替换为强密码
MYSQL_DATABASE=tongshi

# Database pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30

# Redis 缓存配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_SOCKET_TIMEOUT=5

# 第一阶段上线默认使用本地文件存储。
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=/data/tongshi/uploads

# 第二阶段启用 SeaweedFS / MinIO / S3 时再打开以下配置。
# STORAGE_BACKEND=s3
# S3_ENDPOINT=http://localhost:8333
# S3_ACCESS_KEY=请替换
# S3_SECRET_KEY=请替换
# S3_REGION=us-east-1
# S3_BUCKET_PUBLIC=tongshi-public
# S3_BUCKET_PRIVATE=tongshi-private
# S3_FORCE_PATH_STYLE=true
